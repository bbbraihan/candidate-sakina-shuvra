# Copy to .env and adjust as needed
# python-dotenv is loaded automatically if present

# Paths (absolute or relative to repo root)
CORPUS_DIR=dataset
INDEX_DIR=faiss_index
LOG_FILE=logs/requests.jsonl

# LLM
OLLAMA_MODEL=qwen2.5:7b-instruct
OLLAMA_BASE_URL=http://localhost:11434

# Embedding (fixed by spec — do not change)
EMBED_MODEL=BAAI/bge-small-en-v1.5

# Retrieval
TOP_K=5

# Voice
WHISPER_MODEL=small
